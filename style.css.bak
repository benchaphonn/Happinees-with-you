*{
  margin:0;
  padding:0;
  box-sizing:border-box;
}

:root{
  --bg:#cfe8fb;
  --panel:#78b6df;
  --panel-light:#d8efff;
  --text:#202020;
  --black:#111;
}

html,body{
  width:100%;
  min-height:100%;
}

body{
  background:var(--bg);
  font-family:Arial,"Noto Sans Thai",sans-serif;
  color:var(--text);
  overflow-x:hidden;
  overflow-y:auto;
}

.page{
  width:100%;
  min-height:100svh;
  position:relative;
  background:var(--bg);
  overflow:visible;
  display:flex;
  flex-direction:column;
}

.title{
  width:100%;
  text-align:center;
  margin-top:clamp(56px,8vh,86px);
  margin-bottom:0;
  font-size:clamp(24px,2.2vw,32px);
  font-weight:400;
  letter-spacing:.2px;
  z-index:2;
  white-space:nowrap;
  pointer-events:none;
  flex:0 0 auto;
}

body.loading-mode{
  background:#64a7d6;
}

body.loading-mode .page{
  background:#64a7d6;
}

body.loading-mode .title{
  margin-top:clamp(86px,11vh,118px);
  opacity:.34;
  color:#173e5b;
}

.screen{
  width:100%;
  min-height:0;
  flex:1 1 auto;
  display:none;
  flex-direction:column;
  align-items:center;
}
.screen.active{display:flex;}
.hidden{display:none !important;}

/* หน้าแรก */
.start-screen{
  justify-content:flex-start;
  padding-top:clamp(22px,3.2vh,34px);
  padding-bottom:clamp(58px,8vh,88px);
  gap:clamp(28px,4vh,42px);
}
.single-card-wrap{
  display:flex;
  justify-content:center;
  align-items:center;
}
.single-card{
  width:auto;
  height:clamp(480px,70vh,690px);
  max-width:82vw;
  display:block;
  border-radius:30px;
  animation:floatCard 2.6s ease-in-out infinite;
  filter:drop-shadow(0 12px 18px rgba(0,0,0,.11));
}
@keyframes floatCard{
  0%,100%{transform:translateY(0);}
  50%{transform:translateY(-8px);}
}

/* ปุ่มตาม Figma */
.btn{
  min-width:128px;
  height:42px;
  padding:0 24px;
  border-radius:999px;
  border:1.8px solid #111;
  background:#fff;
  color:#111;
  font-size:18px;
  font-weight:400;
  cursor:pointer;
  transition:background .16s ease,color .16s ease,transform .16s ease,box-shadow .16s ease,opacity .16s ease;
  line-height:1;
}
.btn:hover,.btn:focus-visible{
  background:#050505;
  color:#8fd4ff;
  transform:translateY(-2px);
  box-shadow:0 8px 15px rgba(0,0,0,.12);
  outline:none;
}
.btn:active,.btn.is-clicked{
  background:#050505;
  color:#8fd4ff;
  transform:translateY(0) scale(.97);
  box-shadow:none;
}
.btn-secondary{
  border:0;
  background:#eaf8ff;
  color:#8fd4ff;
}
.btn-secondary:hover,.btn-secondary:focus-visible,.btn-secondary:active,.btn-secondary.is-clicked{
  background:#050505;
  color:#8fd4ff;
}
#shuffleBtn{
  margin-top:0;
  flex:0 0 auto;
}

/* Animation สับไพ่ */
.shuffle-screen{
  justify-content:center;
  padding-top:40px;
}
.shuffle-stack{
  position:relative;
  width:520px;
  height:430px;
  display:flex;
  justify-content:center;
  align-items:center;
}
.shuffle-card{
  width:285px;
  border-radius:28px;
  position:absolute;
  filter:drop-shadow(0 14px 22px rgba(0,0,0,.18));
}
.card-a{z-index:2;animation:shuffleA 1.05s ease-in-out forwards;}
.card-b{z-index:1;animation:shuffleB 1.05s ease-in-out forwards;}
@keyframes shuffleA{
  0%{transform:translateX(0) rotate(0deg);}
  35%{transform:translateX(-20px) rotate(-3deg);}
  70%{transform:translateX(8px) rotate(2deg);}
  100%{transform:translateX(-44px) rotate(0deg);}
}
@keyframes shuffleB{
  0%{transform:translateX(0) rotate(0deg);opacity:.92;}
  35%{transform:translateX(58px) rotate(8deg);opacity:1;}
  70%{transform:translateX(38px) rotate(3deg);}
  100%{transform:translateX(82px) rotate(8deg);opacity:1;}
}

/* หน้าเลือกไพ่ */
.pick-screen{
  justify-content:flex-start;
  padding-top:clamp(26px,4vh,44px);
  padding-bottom:clamp(72px,9vh,120px);
}
.deck-area{
  width:920px;
  height:360px;
  position:relative;
  margin-top:clamp(22px,3.2vh,34px);
  filter:drop-shadow(0 12px 16px rgba(0,0,0,.16));
  flex:0 0 auto;
}
.tarot-card{
  width:var(--card-w,240px);
  height:var(--card-h,360px);
  position:absolute;
  border:none;
  background:transparent;
  padding:0;
  cursor:pointer;
  transition:left .42s ease,top .42s ease,transform .28s ease,filter .2s ease,opacity .2s ease;
  transform-origin:center bottom;
}
.tarot-card img{
  width:100%;
  height:100%;
  object-fit:cover;
  border-radius:18px;
  display:block;
  box-shadow:0 5px 10px rgba(0,0,0,.18);
  user-select:none;
  -webkit-user-drag:none;
}
.tarot-card.deal-in{
  animation:dealIn .48s ease both;
  animation-delay:var(--delay,0ms);
}
@keyframes dealIn{
  0%{opacity:0;transform:translate(190px,32px) rotate(0deg) scale(.65);}
  100%{opacity:1;transform:rotate(var(--rot,0deg)) scale(1);}
}
.tarot-card:hover{
  filter:brightness(1.15);
  z-index:800 !important;
}
.tarot-card:active{filter:brightness(.9);}
.tarot-card.selected{z-index:900 !important;}
.tarot-card.selected img{
  box-shadow:0 0 0 3px rgba(255,255,255,.9),0 14px 25px rgba(0,0,0,.28);
}
.pick-text{
  margin-top:clamp(36px,4.7vh,52px);
  font-size:clamp(20px,1.9vw,28px);
  line-height:1;
  font-weight:600;
}
.button-row{
  margin-top:20px;
  display:flex;
  gap:16px;
  align-items:center;
  justify-content:center;
}
#resetBtn,#readBtn{
  min-width:132px;
  height:44px;
  font-size:19px;
}

/* Loading */
.loading-screen{
  background:transparent;
  min-height:0;
  flex:1 1 auto;
  justify-content:center;
  align-items:center;
  padding-top:0;
  padding-bottom:clamp(70px,10vh,120px);
  gap:40px;
}
.loading-title{
  font-size:26px;
  margin:0;
}
.spinner{
  width:72px;
  height:72px;
  border:3px solid #111;
  border-top-color:transparent;
  border-radius:50%;
  margin:0;
  animation:spin .85s linear infinite;
}
@keyframes spin{to{transform:rotate(360deg);}}
.warning{font-size:22px;margin:0;color:#fff;}
.warning b{color:#d81d3c;}

/* ผลลัพธ์ */
.result-screen{
  justify-content:flex-start;
  padding-top:44px;
  padding-bottom:38px;
  min-height:100svh;
  overflow-x:hidden;
}
.result-list{
  width:min(1040px,86vw);
  display:flex;
  flex-direction:column;
  gap:28px;
  margin-bottom:30px;
}
.result-item{
  width:100%;
  min-height:232px;
  background:var(--panel);
  border-radius:12px;
  padding:26px 34px;
  display:grid;
  grid-template-columns:146px 1fr;
  gap:36px;
  align-items:center;
}
.result-card-img{
  width:128px;
  height:auto;
  border-radius:10px;
  align-self:center;
  justify-self:center;
}
.result-content{
  display:flex;
  flex-direction:column;
  gap:14px;
}
.result-title{
  min-height:42px;
  background:var(--panel-light);
  border-radius:8px;
  padding:8px 18px;
  font-size:24px;
  font-weight:700;
  display:flex;
  align-items:center;
}
.result-desc{
  min-height:132px;
  background:var(--panel-light);
  border-radius:8px;
  padding:18px 20px;
  font-size:21px;
  line-height:1.55;
  font-weight:600;
}
.result-again{
  min-width:112px;
  width:112px;
  height:30px;
  font-size:18px;
  padding:0 16px;
  margin-bottom:20px;
}

@media (max-width:900px){
  .title{
    margin-top:clamp(42px,7vh,62px);
    font-size:24px;
  }
  body.loading-mode .title{
    margin-top:clamp(64px,10vh,86px);
  }
  .start-screen{
    padding-top:24px;
    padding-bottom:64px;
  }
  .single-card{
    height:clamp(420px,66vh,590px);
    max-width:86vw;
  }
  #shuffleBtn{
    margin-top:0;
  }
  .pick-screen{
    padding-top:22px;
    padding-bottom:120px;
  }
  .deck-area{
    margin-top:24px;
  }
  .pick-text{
    margin-top:42px;
    font-size:20px;
  }
  .button-row{
    margin-top:20px;
  }
  .result-screen{
    padding-top:36px;
  }
  .result-list{
    width:92vw;
  }
  .result-item{
    grid-template-columns:98px 1fr;
    gap:18px;
    padding:18px;
    min-height:172px;
  }
  .result-card-img{width:92px;}
  .result-title{font-size:17px;}
  .result-desc{font-size:15px;}
}

@media (max-height:720px){
  .title{
    margin-top:38px;
    font-size:clamp(22px,2vw,28px);
  }
  body.loading-mode .title{
    margin-top:52px;
  }
  .start-screen{
    padding-top:16px;
    padding-bottom:54px;
  }
  .loading-screen{
    padding-bottom:70px;
    gap:32px;
  }
  .single-card{
    height:clamp(410px,68vh,560px);
  }
  #shuffleBtn{
    margin-top:0;
    height:40px;
    font-size:17px;
  }
}

@media (max-height:600px){
  .title{
    margin-top:26px;
    font-size:22px;
  }
  .single-card{
    height:clamp(360px,66vh,480px);
  }
  #shuffleBtn{margin-top:0;}
}
